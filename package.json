{
  "name": "vibecodefriendly",
  "version": "0.1.0",
  "description": "A friendly guardrail for AI-generated code — drift detection and sanity checks in plain English, for vibe coders using Cursor, Claude Code, Copilot, and friends.",
  "license": "MIT",
  "author": {
    "name": "Bruno Dykstra",
    "email": "brunodykstra@gmail.com",
    "url": "https://github.com/DykstraBruno"
  },
  "homepage": "https://github.com/DykstraBruno/vibecodefriendly#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DykstraBruno/vibecodefriendly.git"
  },
  "bugs": {
    "url": "https://github.com/DykstraBruno/vibecodefriendly/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "vcf": "./bin/vcf.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "tsc --noEmit && vitest run"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "README.pt-BR.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "ai-coding",
    "vibe-coding",
    "cursor",
    "claude-code",
    "copilot",
    "code-review",
    "drift-detection",
    "guardrail",
    "cli"
  ],
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
